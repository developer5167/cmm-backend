# Server
PORT=5050
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=grace_match
DB_USER=postgres
DB_PASSWORD=admin

# JWT
JWT_SECRET=gracematch_super_secret_jwt_key_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# OTP (MSG91 or Twilio — fill in later)
OTP_PROVIDER=console
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

OTP_EXPIRES_IN_MINUTES=10

# S3 / Storage
S3_BUCKET_NAME=gracematch-media
S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BASE_URL=https://gracematch-media.s3.ap-south-1.amazonaws.com

# Firebase (FCM)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Admin
ADMIN_JWT_SECRET=gracematch_admin_secret_key_change_in_production
